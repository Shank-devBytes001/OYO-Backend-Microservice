PORT=3000
NODE_ENV=development

# ─── MongoDB Atlas (Cloud) ──────────────────────────────────
# Get your connection string from: https://cloud.mongodb.com
# Go to: Database → Connect → Drivers → Copy connection string
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/booking_engine?retryWrites=true&w=majority

# ─── Redis Cloud ────────────────────────────────────────────
# Get your credentials from: https://app.redislabs.com
# Go to: Your Database → Configuration → Public endpoint
REDIS_HOST=your-redis-host.cloud.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=your_redis_password_here

# ─── JWT (change these in production!) ──────────────────────
JWT_ACCESS_SECRET=replace_with_a_random_32_char_string
JWT_REFRESH_SECRET=replace_with_a_different_32_char_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Booking Settings ──────────────────────────────────────
BOOKING_HOLD_TTL=900
CACHE_TTL=60
